# ── Protect sensitive files from being served over the web ───────────────────
<FilesMatch "(^\.env|\.env$|\.sql$|\.txt$|composer\.(json|lock)$|README\.md$)">
    Require all denied
</FilesMatch>

# Block direct web access to internal PHP libraries (they are include-only).
RedirectMatch 403 ^/.*/(includes|config)/.*\.php$

# Never expose dotfiles or the git directory.
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
RedirectMatch 404 ^/\.git

# ── Browser security headers (Pentest finding L1) ────────────────────────────
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
    # CSP allows the Bootstrap/FontAwesome/Google-Fonts CDNs the app loads, blocks
    # framing (clickjacking), and restricts everything else to same-origin.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
</IfModule>
